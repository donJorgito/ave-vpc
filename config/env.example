###############################################################################
# AVE-VPC: Variables de configuracion
#
# Copia este archivo a config/env y rellena tus valores.
# NUNCA subas config/env a git (esta en .gitignore).
###############################################################################

# --- VPS ---
# IP publica del VPS (la obtienes de Oracle Cloud / Hetzner despues de crearlo)
VPS_IP="203.0.113.50"

# Usuario SSH del VPS (Oracle Cloud ARM usa "ubuntu" por defecto)
VPS_USER="ubuntu"

# Puerto SSH del VPS
VPS_SSH_PORT="22"

# --- mlvpn ---
# Puertos UDP que usa mlvpn en el VPS (uno por cada enlace/interfaz)
MLVPN_PORT_1="5080"
MLVPN_PORT_2="5081"

# --- Red del tunel ---
# IP del VPS dentro del tunel mlvpn
TUN_VPS_IP="10.10.10.1"

# IP del Mac dentro del tunel mlvpn
TUN_MAC_IP="10.10.10.2"

# Mascara
TUN_NETMASK="255.255.255.0"

# MTU del tunel (1500 - overhead de mlvpn ~60 bytes)
TUN_MTU="1440"

# --- Interfaces fisicas del Mac ---
# Interfaz Wi-Fi del Mac (conectada al hotspot del iPhone)
# Casi siempre es "en0"
IFACE_IPHONE="en0"

# Interfaz USB del Pixel (tethering por USB)
# Para averiguarlo: ve a Preferencias del Sistema > Red despues de conectar
# el Pixel por USB. Suele ser "en5", "en6" o similar.
# Tambien: networksetup -listallhardwareports
IFACE_PIXEL="en5"
